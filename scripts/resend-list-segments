#!/usr/bin/env bash
set -euo pipefail

: "${RESEND_API_KEY:?Set RESEND_API_KEY to a Resend API key.}"

status_file="$(mktemp)"
body_file="$(mktemp)"
trap 'rm -f "$status_file" "$body_file"' EXIT

curl -sS \
  -o "$body_file" \
  -w "%{http_code}" \
  -H "Authorization: Bearer $RESEND_API_KEY" \
  -H "Content-Type: application/json" \
  "https://api.resend.com/segments" >"$status_file"

status="$(cat "$status_file")"
if [ "$status" = "401" ]; then
  printf '%s\n' "Resend rejected RESEND_API_KEY. Create a full_access API key and export the token that starts with re_." >&2
  exit 1
fi

if [ "$status" -lt 200 ] || [ "$status" -ge 300 ]; then
  printf 'Resend API returned HTTP %s:\n' "$status" >&2
  cat "$body_file" >&2
  printf '\n' >&2
  exit 1
fi

jq '{data: [.data[]? | {id, name, created_at}], has_more}' "$body_file"
