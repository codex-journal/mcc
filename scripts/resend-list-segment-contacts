#!/usr/bin/env bash
set -euo pipefail

: "${RESEND_API_KEY:?Set RESEND_API_KEY to a Resend API key.}"

segment_id="${RESEND_SEGMENT_ID:-aa859afd-e0a1-401a-b8f7-f97fa63d4373}"

status_file="$(mktemp)"
body_file="$(mktemp)"
trap 'rm -f "$status_file" "$body_file"' EXIT

curl -sS \
  -o "$body_file" \
  -w "%{http_code}" \
  -H "Authorization: Bearer $RESEND_API_KEY" \
  -H "Content-Type: application/json" \
  "https://api.resend.com/segments/$segment_id/contacts" >"$status_file"

status="$(cat "$status_file")"
if [ "$status" -ge 200 ] && [ "$status" -lt 300 ]; then
  jq '{data: [.data[]? | {id, email, unsubscribed, created_at}], has_more}' "$body_file"
  exit 0
fi

printf 'Resend API returned HTTP %s:\n' "$status" >&2
cat "$body_file" >&2
printf '\n' >&2
exit 1
